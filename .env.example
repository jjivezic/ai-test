# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=hyper_db

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET=your-s3-bucket-name

# Email Configuration (Gmail OAuth2)
GOOGLE_EMAIL_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_EMAIL_CLIENT_SECRET=your-google-client-secret
GOOGLE_EMAIL_REFRESH_TOKEN=your-refresh-token
GOOGLE_EMAIL_USER=your-gmail@gmail.com
EMAIL_FROM_NAME=Your App Name
GOOGLE_DRIVE_CLIENT_EMAIL=your-google-drive-client-email
GOOGLE_DRIVE_PRIVATE_KEY=your-google-drive-private-key
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id
GOOGLE_DRIVE_FOLDER_ROOT_NAME=OPENIAI

FRONTEND_URL=http://localhost:3001

AI_PROVIDER=ai_provider
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_key
# ============================================
# Vector Database Configuration
# ============================================
# Provider selection: chroma (default), pinecone, qdrant, weaviate
VECTOR_DB_PROVIDER=chroma

# ChromaDB (default, local)
# Run: chroma run --path ./chroma_data
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION_NAME=documents

# Pinecone (cloud)
# Sign up at https://www.pinecone.io
#PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=documents

# Qdrant (self-hosted or cloud)
# Run: docker run -p 6333:6333 qdrant/qdrant
# Or sign up at https://qdrant.tech
QDRANT_URL=http://localhost:6333
#QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documents

# Weaviate (self-hosted or cloud)
# Run: docker run -p 8080:8080 semitechnologies/weaviate:latest
# Or sign up at https://console.weaviate.cloud
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_SCHEME=http
#WEAVIATE_API_KEY=
WEAVIATE_CLASS_NAME=Document

